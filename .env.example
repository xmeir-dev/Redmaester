# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/redmaester?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/redmaester?schema=public"
SEED_DEMO_DATA="false"

# --- AI models (leave ANTHROPIC_API_KEY empty to use the keyword fallback classifier) ---
ANTHROPIC_API_KEY=""
BOOKMARK_CLASSIFICATION_MODEL="claude-3-haiku-20240307"
MICRO_SKILL_MODEL="claude-sonnet-4-6"
MASTER_SKILL_MODEL="claude-sonnet-4-6"
CHAT_MODEL="claude-sonnet-4-6"
ROUTING_MODEL="claude-sonnet-4-6"
ROUTING_CONFIDENCE_THRESHOLD="0.65"
ROUTING_MODEL_TIMEOUT_MS="5000"

# --- Classification thresholds ---
CLASSIFICATION_AUTO_CREATE_THRESHOLD="0.85"
CLASSIFICATION_REFERENCE_THRESHOLD="0.50"
CLASSIFICATION_REVIEW_THRESHOLD="0.40"

# --- Ask / chat ---
CHAT_MODEL_TIMEOUT_MS="60000"
CHAT_EVIDENCE_LIMIT="220"
CHAT_CHUNK_SIZE="24"
CHAT_MAX_CHUNKS="4"

# --- Budget guardrail (monthly USD cap + per-operation cost estimates) ---
MONTHLY_BUDGET_USD="30"
ESTIMATED_ROUTE_COST_USD="0.005"
ESTIMATED_CLASSIFICATION_COST_USD="0.03"
ESTIMATED_MICRO_SKILL_COST_USD="0.08"
ESTIMATED_MASTER_SKILL_COST_USD="0.12"

# --- Sync ---
AUTO_SYNC_INTERVAL_MINUTES="5"
INITIAL_SYNC_DEFAULT_LIMIT="500"
BACKFILL_CHUNK_LIMIT="500"
AUTO_SYNC_LOOKBACK_LIMIT="500"
FULL_SYNC_PAGE_SIZE="50"
FULL_SYNC_MAX_PAGES="20"
FULL_SYNC_MAX_BOOKMARKS="1000"
CRON_SECRET=""

# --- X (Twitter) API — USE_MOCK_X=true runs the full app on mock bookmarks ---
USE_MOCK_X="true"
X_API_BASE_URL="https://api.x.com"
X_OAUTH_SCOPES="tweet.read users.read bookmark.read offline.access"
X_DEFAULT_USER_ID=""
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_REDIRECT_URI="http://localhost:3000/api/auth/x/callback"

# --- Enrichment (URL content fetching) ---
ENRICHMENT_FETCH_TIMEOUT_MS="10000"
ENRICHMENT_MAX_URLS="5"
PLAYWRIGHT_TIMEOUT_MS="30000"
# Local dev only: allow Playwright to reuse cookies from your own installed
# Chromium browsers (Arc/Chrome/Brave) via the macOS Keychain
ENABLE_KEYCHAIN_ACCESS="false"
BROWSERBASE_API_KEY=""
BROWSERBASE_PROJECT_ID=""
BROWSERBASE_CONTEXT_ID=""

# --- Agent workspace delivery (optional) ---
OPENCLAW_WORKSPACE=""
